generator client {
  provider = "prisma-client-js"
  output   = "../../../generated/grade-service-client"
}

datasource db {
  provider = "postgresql"
}

model Grade {
  id          String   @id @default(uuid())
  studentId   String
  professorId String
  classId     String?
  courseName  String
  value       Float
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([studentId])
  @@index([classId])
  @@index([courseName])
}
