generator client {
  provider = "prisma-client-js"
  output   = "../../../generated/grade-service-client"
}

datasource db {
  provider = "postgresql"
}

model Grade {
  id          String   @id @default(uuid())
  studentId   String
  courseName  String
  value       Float
  professorId String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
